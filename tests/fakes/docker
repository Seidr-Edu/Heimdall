def _run_kvasir(container: _ContainerMounts, manifest: dict[str, Any], mode: str) -> None:
    run_root = container.resolve("/run")
    outputs_dir = run_root / "outputs"
    outputs_dir.mkdir(parents=True, exist_ok=True)
    status = "passed"
    behavioral_verdict = "pass"
    reason = None
    if mode == "behavioral-fail":
        behavioral_verdict = "fail"
    elif mode == "failed-report":
        status = "failed"
        behavioral_verdict = "fail"
        reason = "fake-kvasir-failure"
    elif mode == "error-report":
        status = "error"
        behavioral_verdict = "fail"
        reason = "fake-kvasir-error"
    _write_json(
        outputs_dir / "test_port.json",
        {
            "status": status,
            "behavioral_verdict": behavioral_verdict,
            "reason": reason,
            "run_id": manifest.get("run_id"),
        },
    )


def _run_lidskjalv(container: _ContainerMounts, manifest: dict[str, Any], mode: str) -> None:
    run_root = container.resolve("/run")
    scan_label = str(manifest.get("scan_label", "original"))
    skip_sonar = bool(manifest.get("skip_sonar", False))
    scan_dir = run_root / "artifacts" / "scans" / scan_label
    (scan_dir / "logs").mkdir(parents=True, exist_ok=True)
    (scan_dir / "metadata").mkdir(parents=True, exist_ok=True)
    (scan_dir / "workspace" / "repo").mkdir(parents=True, exist_ok=True)
    _write_json(scan_dir / "metadata" / "scan-state.json", {"scan_label": scan_label})
    status = "passed"
    reason = None
    task_id_raw = os.environ.get("FAKE_DOCKER_LIDSKJALV_TASK_ID")
    sonar_task_id = None
    if not skip_sonar:
        sonar_task_id = (
            task_id_raw if task_id_raw is not None else f"fake-{scan_label}-task"
        )
        if sonar_task_id == "":
            sonar_task_id = None
    if mode == "failed-report":
        status = "failed"
        reason = f"fake-lidskjalv-{scan_label}-failure"
    elif mode == "error-report":
        status = "error"
        reason = f"fake-lidskjalv-{scan_label}-error"
    _write_json(
        run_root / "outputs" / "run_report.json",
        {
            "status": status,
            "run_id": manifest.get("run_id"),
            "scan_label": scan_label,
            "project_key": manifest.get("project_key"),
            "project_name": manifest.get("project_name"),
            "reason": reason,
            "scan": {
                "build_tool": "maven",
                "build_jdk": "21",
                "sonar_task_id": sonar_task_id,
                "ce_task_status": None,
                "quality_gate_status": "skipped" if skip_sonar else None,
                "data_status": "skipped" if skip_sonar else "pending",
                "measures": {},
            },
        },
    )
    _write_summary(run_root / "outputs" / "summary.md", f"Lidskjalv {scan_label}")


def _write_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


def _write_summary(path: Path, title: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(f"# {title}\n", encoding="utf-8")


def _image_id(image_ref: str) -> str:
    digest = hashlib.sha256(image_ref.encode("utf-8")).hexdigest()
    return f"sha256:{digest}"


def _csv_env(name: str) -> set[str]:
    value = os.environ.get(name, "")
    if not value:
        return set()
    return {item.strip() for item in value.split(",") if item.strip()}


def _record_command(entry: dict[str, Any]) -> None:
    def update(state: dict[str, Any]) -> None:
        _append_command(state, entry)

    _mutate_state(update)


def _append_command(state: dict[str, Any], entry: dict[str, Any]) -> dict[str, Any]:
    sequence = int(state.get("next_seq", 1))
    state["next_seq"] = sequence + 1
    record = dict(entry)
    record["seq"] = sequence
    state.setdefault("commands", []).append(record)
    return record


def _mutate_state(callback) -> None:
    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    with STATE_PATH.open("a+", encoding="utf-8") as handle:
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
        handle.seek(0)
        raw = handle.read().strip()
        state = json.loads(raw) if raw else {"available": {}, "commands": [], "runs": [], "next_seq": 1}
        callback(state)
        handle.seek(0)
        handle.truncate()
        handle.write(json.dumps(state, indent=2) + "\n")
        handle.flush()
        os.fsync(handle.fileno())
        fcntl.flock(handle.fileno(), fcntl.LOCK_UN)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
