STATE_PATH = Path(os.environ["FAKE_DOCKER_STATE"])


def main(argv: list[str]) -> int:
    if len(argv) < 2:
        print("missing docker subcommand", file=sys.stderr)
        return 1
    command = argv[1]
    if command == "version":
        _record_command({"kind": "version", "args": argv[2:]})
        print(os.environ.get("FAKE_DOCKER_SERVER_VERSION", "26.1.0"))
        return 0
    if command == "pull":
        if len(argv) != 3:
            print("usage: docker pull <image>", file=sys.stderr)
            return 1
        image_ref = argv[2]
        return _handle_pull(image_ref)
    if command == "image" and len(argv) >= 5 and argv[2] == "inspect":
        return _handle_inspect(argv[3])
    if command == "run":
        return _handle_run(argv[2:])
    print(f"unsupported fake docker command: {' '.join(argv[1:])}", file=sys.stderr)
    return 1


def _handle_pull(image_ref: str) -> int:
    if image_ref in _csv_env("FAKE_DOCKER_PULL_FAIL_REFS"):
        print(f"pull denied for {image_ref}", file=sys.stderr)
        return 1

    def update(state: dict[str, Any]) -> None:
        state.setdefault("available", {})[image_ref] = _image_id(image_ref)
        _append_command(state, {"kind": "pull", "image": image_ref})

    _mutate_state(update)
    print(f"Pulled {image_ref}")
    return 0


def _handle_inspect(image_ref: str) -> int:
    image_id: str | None = None

    def update(state: dict[str, Any]) -> None:
        nonlocal image_id
        image_id = state.setdefault("available", {}).get(image_ref)
        _append_command(state, {"kind": "inspect", "image": image_ref, "found": image_id is not None})

    _mutate_state(update)
    if image_id is None:
        print(f"Error: No such image: {image_ref}", file=sys.stderr)
        return 1
    print(image_id)
    return 0


def _handle_run(args: list[str]) -> int:
    env_vars: dict[str, str] = {}
    mounts: list[dict[str, Any]] = []
    entrypoint: str | None = None
    idx = 0
    while idx < len(args):
        token = args[idx]
        if token == "--rm":
            idx += 1
            continue
        if token == "--entrypoint":
            entrypoint = args[idx + 1]
            idx += 2
            continue
        if token == "-e":
            key, value = args[idx + 1].split("=", 1)
            env_vars[key] = value
            idx += 2
            continue
        if token == "-v":
            mounts.append(_parse_mount(args[idx + 1]))
            idx += 2
            continue
        break
    if idx >= len(args):
        print("fake docker run missing image ref", file=sys.stderr)
        return 1
    image_ref = args[idx]
    run_args = args[idx + 1 :]

    container = _ContainerMounts(mounts)
    if "HEIMDALL_SMOKE_SERVICE" in env_vars:
        step = f"smoke-{env_vars['HEIMDALL_SMOKE_SERVICE']}"
        mode = os.environ.get(
            f"FAKE_DOCKER_SMOKE_{env_vars['HEIMDALL_SMOKE_SERVICE'].upper()}_MODE",
            "pass",
        )
        manifest: dict[str, Any] = {}
    else:
        manifest = _load_manifest(container, env_vars)
        step = _infer_step(image_ref, manifest, mounts)
        mode = os.environ.get(f"FAKE_DOCKER_{step.upper().replace('-', '_')}_MODE", "pass")
        if step.startswith("lidskjalv-"):
            mode = os.environ.get(
                f"FAKE_DOCKER_{step.upper().replace('-', '_')}_MODE", mode
            )

    run_entry: dict[str, Any] = {
        "kind": "run",
        "image": image_ref,
        "step": step,
        "mode": mode,
        "entrypoint": entrypoint,
        "env": env_vars,
        "mounts": mounts,
        "args": run_args,
        "manifest": manifest,
    }

    def update(state: dict[str, Any]) -> None:
        record = _append_command(state, run_entry)
        state.setdefault("runs", []).append({k: v for k, v in record.items() if k != "kind"})

    _mutate_state(update)

    _maybe_sleep(step)
    if mode == "missing-report":
        return 0
    if step.startswith("smoke-"):
        return _run_provider_smoke(container, env_vars, mode)
    if step == "brokk":
        _run_brokk(container, manifest, mode)
    elif step == "eitri" or step.startswith("eitri-generated"):
        _run_eitri(container, manifest, mode)
    elif step == "andvari" or step.startswith("andvari-"):
        _run_andvari(container, manifest, mode)
    elif step == "mimir" or step.startswith("mimir-"):
        _run_mimir(container, manifest, mode)
    elif step == "kvasir" or step.startswith("kvasir-"):
        _run_kvasir(container, manifest, mode)
    elif step.startswith("lidskjalv-"):
        _run_lidskjalv(container, manifest, mode)
    else:
        print(f"unknown fake step for image {image_ref}", file=sys.stderr)
        return 1
    if mode == "nonzero-after-report":
        return 1
    return 0


class _ContainerMounts:
    def __init__(self, mounts: list[dict[str, Any]]) -> None:
        self.mounts = mounts

    def resolve(self, container_path: str) -> Path:
        candidates = sorted(self.mounts, key=lambda item: len(item["container"]), reverse=True)
        for mount in candidates:
            container_root = mount["container"]
            if container_path == container_root:
                return Path(mount["host"])
            prefix = container_root.rstrip("/") + "/"
            if container_path.startswith(prefix):
                suffix = container_path[len(prefix) :]
                return Path(mount["host"]) / suffix
        raise RuntimeError(f"fake docker could not resolve container path: {container_path}")


def _parse_mount(spec: str) -> dict[str, Any]:
    host, container, *rest = spec.split(":")
    return {
        "host": host,
        "container": container,
        "read_only": "ro" in rest,
    }


def _load_manifest(container: _ContainerMounts, env_vars: dict[str, str]) -> dict[str, Any]:
    for key in (
        "BROKK_MANIFEST",
        "EITRI_MANIFEST",
        "ANDVARI_MANIFEST",
        "MIMIR_MANIFEST",
        "KVASIR_MANIFEST",
        "LIDSKJALV_MANIFEST",
    ):
        if key in env_vars:
            manifest_path = env_vars[key]
            break
    else:
        manifest_path = "/run/config/manifest.yaml"
    path = container.resolve(manifest_path)
    if not path.is_file():
        return {}
    loaded = loads(path.read_text(encoding="utf-8"))
    return dict(loaded) if isinstance(loaded, dict) else {}


def _infer_step(
    image_ref: str, manifest: dict[str, Any], mounts: list[dict[str, Any]]
) -> str:
    service_name = _service_name_from_mounts(mounts)
    if service_name is not None:
        return service_name
    lowered = image_ref.lower()
    if "brokk" in lowered:
        return "brokk"
    if "eitri" in lowered:
        if any("/services/eitri-generated/" in mount["host"] for mount in mounts):
            return "eitri-generated"
        return "eitri"
    if "andvari" in lowered:
        return "andvari"
    if "mimir" in lowered:
        return "mimir"
    if "kvasir" in lowered:
        return "kvasir"
    if "lidskjalv" in lowered:
        label = str(manifest.get("scan_label", "original"))
        return f"lidskjalv-{label}"
    return "unknown"


def _service_name_from_mounts(mounts: list[dict[str, Any]]) -> str | None:
    for mount in mounts:
        if mount.get("container") not in {"/run", "/run/config"}:
            continue
        parts = Path(str(mount["host"])).parts
        for index, part in enumerate(parts[:-1]):
            if part != "services":
                continue
            service = parts[index + 1]
            if service and service not in {".", ".."}:
                return service
    return None


def _maybe_sleep(step: str) -> None:
    env_name = f"FAKE_DOCKER_{step.upper().replace('-', '_')}_SLEEP_SEC"
    raw = os.environ.get(env_name)
    if raw is None:
        return
    try:
        seconds = float(raw)
    except ValueError:
        return
    if seconds > 0:
        time.sleep(seconds)


def _run_provider_smoke(
    container: _ContainerMounts, env_vars: dict[str, str], mode: str
) -> int:
    runtime_dir = container.resolve("/run/provider-state/codex-home")
    runtime_dir.mkdir(parents=True, exist_ok=True)
    workspace_dir = container.resolve("/run/workspace")
    workspace_dir.mkdir(parents=True, exist_ok=True)
    provider_seed = container.resolve("/opt/provider-seed/codex-home")
    smoke_input = container.resolve("/input/smoke.txt")
    if provider_seed.exists():
        shutil.copytree(provider_seed, runtime_dir, dirs_exist_ok=True)

    service = env_vars.get("HEIMDALL_SMOKE_SERVICE", "unknown")
    print(f"[smoke] service={service}")
    print("/opt/provider/bin/codex")

    if mode == "version-fail":
        print("/opt/provider/bin/codex: cannot execute binary file: Exec format error")
        return 1
    if mode == "login-fail":
        print("codex-cli 0.113.0")
        print("Not logged in")
        return 1
    if mode == "exec-fail":
        print("codex-cli 0.113.0")
        print("Logged in using ChatGPT")
        print("sandbox denied access to /input/smoke.txt")
        print(
            "[smoke][error] command failed: codex exec --skip-git-repo-check "
            "--dangerously-bypass-approvals-and-sandbox --cd /run/workspace "
            "--add-dir /input --json --output-last-message "
            "/run/workspace/last-message.txt - (exit 1)"
        )
        return 1
    if mode == "exec-no-artifact":
        print("codex-cli 0.113.0")
        print("Logged in using ChatGPT")
        print("SMOKE_OK")
        print("[smoke][error] codex exec did not create /run/workspace/smoke-result.txt")
        return 1

    print("codex-cli 0.113.0")
    print("Logged in using ChatGPT")
    if smoke_input.exists():
        shutil.copy2(smoke_input, workspace_dir / "smoke-result.txt")
    (workspace_dir / "last-message.txt").write_text("SMOKE_OK\n", encoding="utf-8")
    print("SMOKE_OK")
    print("[smoke] codex exec workspace probe passed")
    print("[smoke] provider smoke passed")
    return 0


def _run_brokk(container: _ContainerMounts, manifest: dict[str, Any], mode: str) -> None:
    run_root = container.resolve("/run")
    source_manifest_path = run_root / "inputs" / "source-manifest.json"
    original_repo = run_root / "artifacts" / "original-repo"
    logs_dir = run_root / "artifacts" / "brokk" / "logs"
    original_repo.mkdir(parents=True, exist_ok=True)
    logs_dir.mkdir(parents=True, exist_ok=True)
    (original_repo / "README.md").write_text("original repo\n", encoding="utf-8")
    _write_json(
        source_manifest_path,
        {
            "repo_url": manifest.get("repo_url"),
            "commit_sha": manifest.get("commit_sha"),
        },
    )
    _write_json(
        run_root / "outputs" / "run_report.json",
        {
            "status": "passed" if mode == "pass" else "failed",
            "run_id": manifest.get("run_id"),
            "reason": None if mode == "pass" else "fake-brokk-failure",
        },
    )
    _write_summary(run_root / "outputs" / "summary.md", "Brokk")


