def _run_mimir(container: _ContainerMounts, manifest: dict[str, Any], mode: str) -> None:
    run_root = container.resolve("/run")
    comparisons_dir = run_root / "artifacts" / "comparisons"
    comparisons_dir.mkdir(parents=True, exist_ok=True)
    diagram_comparisons: dict[str, Any] = {}
    for candidate in manifest.get("candidates", []):
        if not isinstance(candidate, dict):
            continue
        label = str(candidate.get("label", "candidate"))
        artifact_path = comparisons_dir / f"{label}.json"
        payload = {
            "schema_version": "uml_model_diff.v1",
            "baseline_label": manifest.get("baseline_label", "original"),
            "candidate_label": label,
            "exact_similarity": 1.0 if mode == "pass" else 0.5,
            "fuzzy_similarity": 1.0 if mode == "pass" else 0.75,
            "component_scores": {
                "exact": {
                    "packages": 1.0,
                    "types": 1.0,
                    "fields": 1.0,
                    "methods": 1.0,
                    "relations": 1.0,
                },
                "fuzzy": {
                    "matched_type_coverage": 1.0,
                    "field_preservation": 1.0,
                    "method_preservation": 1.0,
                    "relation_preservation": 1.0,
                    "name_package_retention": 1.0,
                },
            },
            "diff_counts": {
                "missing_packages": 0,
                "added_packages": 0,
                "missing_types": 0,
                "added_types": 0,
                "likely_renamed_or_moved_types": 0,
                "missing_fields": 0,
                "added_fields": 0,
                "changed_fields": 0,
                "missing_methods": 0,
                "added_methods": 0,
                "changed_methods": 0,
                "missing_relations": 0,
                "added_relations": 0,
                "changed_relations": 0,
            },
            "package_diff": {"missing": [], "added": []},
            "type_diff": {"missing": [], "added": [], "likely_renamed_or_moved": []},
            "field_diff": {"missing": [], "added": [], "changed": []},
            "method_diff": {"missing": [], "added": [], "changed": []},
            "relation_diff": {"missing": [], "added": [], "changed": []},
            "top_mismatches": [],
        }
        _write_json(artifact_path, payload)
        diagram_comparisons[label] = {
            "exact_similarity": payload["exact_similarity"],
            "fuzzy_similarity": payload["fuzzy_similarity"],
            "component_scores": payload["component_scores"],
            "diff_counts": payload["diff_counts"],
            "artifact_path": str(artifact_path),
        }
    _write_json(
        comparisons_dir / "aggregate.json",
        {
            "schema_version": "uml_model_comparison_aggregate.v1",
            "run_id": manifest.get("run_id"),
            "baseline_label": manifest.get("baseline_label"),
            "comparisons": diagram_comparisons,
        },
    )
    _write_json(
        run_root / "outputs" / "run_report.json",
        {
            "status": "passed" if mode == "pass" else "failed",
            "run_id": manifest.get("run_id"),
            "reason": None if mode == "pass" else "fake-mimir-failure",
            "mode": manifest.get("mode"),
            "comparison_count": len(diagram_comparisons),
            "diagram_comparisons": diagram_comparisons,
            "artifacts": {
                "comparison_dir": "/run/artifacts/comparisons",
                "aggregate_path": "/run/artifacts/comparisons/aggregate.json",
                "logs_dir": "/run/artifacts/mimir/logs",
            },
        },
    )
    _write_summary(run_root / "outputs" / "summary.md", "Mimir")


def _run_kvasir(container: _ContainerMounts, manifest: dict[str, Any], mode: str) -> None:
    run_root = container.resolve("/run")
    outputs_dir = run_root / "outputs"
    ported_repo = run_root / "artifacts" / "ported-tests-repo"
    outputs_dir.mkdir(parents=True, exist_ok=True)
    ported_repo.mkdir(parents=True, exist_ok=True)
    (ported_repo / "README.md").write_text("ported repo\n", encoding="utf-8")
    status = "passed"
    verdict = "no_difference_detected"
    reason = None
    verdict_reason = None
    if mode == "behavioral-fail":
        verdict = "difference_detected"
        verdict_reason = "ported-tests-failed"
    elif mode == "nonzero-after-report":
        status = "skipped"
        verdict = "skipped"
        reason = "invalid-service-config"
        verdict_reason = "policy_override_rejected"
    elif mode == "failed-report":
        status = "failed"
        verdict = "inconclusive"
        reason = "fake-kvasir-failure"
    elif mode == "error-report":
        status = "error"
        verdict = "invalid"
        reason = "fake-kvasir-error"
    _write_json(
        outputs_dir / "test_port.json",
        {
            "schema_version": "kvasir.test_port.v3",
            "run_id": manifest.get("run_id"),
            "result": {
                "status": status,
                "reason": reason,
                "verdict": verdict,
                "verdict_reason": verdict_reason,
            },
            "artifacts": {
                "ported_repo": "/run/artifacts/ported-tests-repo",
            },
        },
    )


def _run_lidskjalv(container: _ContainerMounts, manifest: dict[str, Any], mode: str) -> None:
    run_root = container.resolve("/run")
    scan_label = str(manifest.get("scan_label", "original"))
    skip_sonar = bool(manifest.get("skip_sonar", False))
    scan_dir = run_root / "artifacts" / "scans" / scan_label
    (scan_dir / "logs").mkdir(parents=True, exist_ok=True)
    (scan_dir / "metadata").mkdir(parents=True, exist_ok=True)
    (scan_dir / "workspace" / "repo").mkdir(parents=True, exist_ok=True)
    _write_json(scan_dir / "metadata" / "scan-state.json", {"scan_label": scan_label})
    status = "passed"
    reason = None
    task_id_raw = os.environ.get("FAKE_DOCKER_LIDSKJALV_TASK_ID")
    sonar_task_id = None
    if not skip_sonar:
        sonar_task_id = (
            task_id_raw if task_id_raw is not None else f"fake-{scan_label}-task"
        )
        if sonar_task_id == "":
            sonar_task_id = None
    if mode == "failed-report":
        status = "failed"
        reason = f"fake-lidskjalv-{scan_label}-failure"
    elif mode == "error-report":
        status = "error"
        reason = f"fake-lidskjalv-{scan_label}-error"
    _write_json(
        run_root / "outputs" / "run_report.json",
        {
            "status": status,
            "run_id": manifest.get("run_id"),
            "scan_label": scan_label,
            "project_key": manifest.get("project_key"),
            "project_name": manifest.get("project_name"),
            "reason": reason,
            "scan": {
                "build_tool": "maven",
                "build_jdk": "21",
                "sonar_task_id": sonar_task_id,
                "ce_task_status": None,
                "quality_gate_status": "skipped" if skip_sonar else None,
                "data_status": "skipped" if skip_sonar else "pending",
                "measures": {},
            },
        },
    )
    _write_summary(run_root / "outputs" / "summary.md", f"Lidskjalv {scan_label}")


def _write_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


def _write_summary(path: Path, title: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(f"# {title}\n", encoding="utf-8")


def _should_generate_degraded_diagrams(manifest: dict[str, Any]) -> bool:
    writers = manifest.get("writers")
    if not isinstance(writers, dict):
        return True
    plantuml = writers.get("plantuml")
    if not isinstance(plantuml, dict):
        return True
    raw = plantuml.get("generateDegradedDiagrams")
    return raw is not False


def _image_id(image_ref: str) -> str:
    digest = hashlib.sha256(image_ref.encode("utf-8")).hexdigest()
    return f"sha256:{digest}"


def _csv_env(name: str) -> set[str]:
    value = os.environ.get(name, "")
    if not value:
        return set()
    return {item.strip() for item in value.split(",") if item.strip()}


def _record_command(entry: dict[str, Any]) -> None:
    def update(state: dict[str, Any]) -> None:
        _append_command(state, entry)

    _mutate_state(update)


def _append_command(state: dict[str, Any], entry: dict[str, Any]) -> dict[str, Any]:
    sequence = int(state.get("next_seq", 1))
    state["next_seq"] = sequence + 1
    record = dict(entry)
    record["seq"] = sequence
    state.setdefault("commands", []).append(record)
    return record


def _mutate_state(callback) -> None:
    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    with STATE_PATH.open("a+", encoding="utf-8") as handle:
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
        handle.seek(0)
        raw = handle.read().strip()
        state = json.loads(raw) if raw else {"available": {}, "commands": [], "runs": [], "next_seq": 1}
        callback(state)
        handle.seek(0)
        handle.truncate()
        handle.write(json.dumps(state, indent=2) + "\n")
        handle.flush()
        os.fsync(handle.fileno())
        fcntl.flock(handle.fileno(), fcntl.LOCK_UN)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
